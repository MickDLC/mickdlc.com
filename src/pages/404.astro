---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Page not found · Mick DeLaCruz" description="The page you were looking for doesn't exist.">
  <main class="container nf">
    <p class="code mono">HTTP/1.1 404 Not Found</p>
    <h1>Page not found.</h1>
    <p class="muted">
      The path you tried doesn't exist on this server. It may have moved, been renamed, or never existed in the
      first place.
    </p>
    <div class="actions">
      <a class="btn btn-primary" href="/"><span class="mono">←</span> Back to home</a>
      <a class="btn" href="/MDeLaCruz_Resume.pdf">Resume (PDF)</a>
    </div>
    <pre class="trace mono"><code>{`$ curl -I https://mickdlc.com${Astro.url.pathname}
HTTP/1.1 404 Not Found
server: cloudflare
content-type: text/html
x-suggestion: try the home page`}</code></pre>
  </main>
</Layout>

<style>
  .nf {
    min-height: calc(100vh - 4rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 4rem;
    padding-bottom: 4rem;
    gap: 0.5rem;
  }

  .code {
    color: var(--accent);
    font-size: 0.85rem;
    margin: 0 0 0.5rem;
  }

  .nf h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin: 0 0 1rem;
  }

  .nf .muted {
    max-width: 520px;
    font-size: 1.05rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.5rem 0 2rem;
  }

  .trace {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    overflow-x: auto;
    max-width: 640px;
  }

  .trace code {
    color: var(--text-muted);
    background: none;
    padding: 0;
    white-space: pre;
  }
</style>
