---
const jobs = [
  {
    title: "IT Operations Engineer",
    company: "Peddle, LLC",
    location: "Austin, TX",
    period: "Jul 2025 — Present",
    summary:
      "Manage role-based access and least-privilege controls for the org. Identity, endpoints, and integrations.",
    bullets: [
      "Administer access for 400+ users and 200+ applications in Okta via SCIM provisioning.",
      "Automate user onboarding and offboarding through Google Workspace APIs.",
      "Provide endpoint support across macOS, Windows, Unifi network gear, and workstation peripherals.",
      "Migrated 100+ offshore email domains to the corporate (EPO) domain to centralize administration and harden security.",
      "Run user and license audits across SaaS platforms; manage Talkdesk numbers and studio flows.",
      "Maintain technical documentation and runbooks to support team knowledge sharing.",
    ],
  },
  {
    title: "IT Administrator I // IT Service Management Specialist II",
    company: "ASM Research / Accenture Federal Services (DOEd)",
    location: "San Antonio, TX",
    period: "Dec 2024 — Jul 2025",
    summary:
      "Tier-2 production support for data-intensive Java Batch applications on a federal government contract.",
    bullets: [
      "Operated and troubleshot long-running Java Batch jobs in production, including incident response and root-cause analysis.",
      "Worked daily with Ansible Automation Platform, Jenkins, and GitLab for CI/CD and operational management.",
      "Triaged incidents from Splunk and monitoring systems; resolved issues raised by testers and users.",
      "Assisted in managing Linux infrastructure on AWS.",
      "Participated in 24/7 on-call rotation for critical production systems.",
    ],
  },
  {
    title: "System Administrator — Internship",
    company: "Quest Logic Solutions",
    location: "Riverdale Park, MD (Remote)",
    period: "Apr 2023 — Dec 2024",
    summary:
      "Provisioned, configured, and maintained Linux and Windows server infrastructure end-to-end.",
    bullets: [
      "Joined Linux and Windows hosts to Active Directory; managed AD and Group Policy.",
      "Hardened Linux systems with firewalld and ufw rule sets.",
      "Edited core Linux config — network settings, service files, crontab — across provisioned hosts.",
      "Provisioned Linux servers, Windows servers, and Windows clients for the team.",
      "Authored documentation, user guides, diagrams, and SOPs.",
    ],
  },
];
---

<section id="experience">
  <div class="container">
    <span class="section-label">experience</span>
    <h2>Work</h2>
    <div class="timeline">
      {
        jobs.map((job) => (
          <article class="job card">
            <header class="job-head">
              <div>
                <h3>{job.title}</h3>
                <p class="company mono">
                  {job.company} <span class="muted">· {job.location}</span>
                </p>
              </div>
              <span class="period mono muted">{job.period}</span>
            </header>
            <p class="summary muted">{job.summary}</p>
            <ul>
              {job.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 1.5rem;
  }

  .job-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .company {
    margin: 0.15rem 0 0;
    color: var(--text);
    font-size: 0.9rem;
  }

  .period {
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .summary {
    margin: 0.5rem 0 0.75rem;
  }

  ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--text-muted);
  }

  li {
    margin-bottom: 0.35rem;
  }

  li::marker {
    color: var(--accent);
  }
</style>
