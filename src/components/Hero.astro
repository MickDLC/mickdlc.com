<header class="hero">
  <div class="container hero-inner">
    <div class="status">
      <span class="dot"></span>
      <span class="mono">Active Public Trust Clearance</span>
    </div>
    <h1>
      Mick DeLaCruz
    </h1>
    <p class="role mono">Systems Administrator · IT Operations Engineer</p>
    <p class="tagline">
      Designing, hardening, and automating server infrastructure across Linux, Windows, and cloud platforms.
      Currently keeping identity, access, and endpoints running cleanly at <a href="https://www.peddle.com" rel="noopener noreferrer" target="_blank">Peddle</a>.
    </p>
    <div class="meta mono">
      <span>Kyle, TX</span>
      <span class="sep">·</span>
      <a href="mailto:mick@mickdlc.com">mick@mickdlc.com</a>
      <span class="sep">·</span>
      <a href="/MDeLaCruz_Resume.pdf">Resume (PDF)</a>
    </div>
    <nav class="nav">
      <a href="#about">About</a>
      <a href="#skills">Skills</a>
      <a href="#experience">Experience</a>
      <a href="#certifications">Certifications</a>
      <a href="#contact">Contact</a>
    </nav>
  </div>
</header>

<style>
  .hero {
    padding: 5rem 0 3rem;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    align-self: flex-start;
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.78rem;
    border: 1px solid rgba(94, 234, 212, 0.25);
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 4px rgba(94, 234, 212, 0.18);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 4px rgba(94, 234, 212, 0.18); }
    50% { box-shadow: 0 0 0 8px rgba(94, 234, 212, 0.05); }
  }

  .role {
    color: var(--text-muted);
    font-size: 1rem;
    margin: 0;
  }

  .tagline {
    max-width: 620px;
    color: var(--text-muted);
    font-size: 1.05rem;
    margin: 0.75rem 0 0.25rem;
  }

  .tagline a {
    color: var(--text);
    border-bottom: 1px dashed var(--accent);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .meta .sep { opacity: 0.4; }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-top: 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
  }

  .nav a {
    color: var(--text-muted);
  }

  .nav a:hover {
    color: var(--accent);
  }
</style>
