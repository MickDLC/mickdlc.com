---
const skillGroups = [
  {
    name: "Operating Systems",
    items: ["Linux (RHEL, CentOS, Ubuntu)", "Windows / Windows Server", "macOS"],
  },
  {
    name: "Networking",
    items: ["DNS", "DHCP", "TCP/UDP", "HTTP/HTTPS", "SSH", "LDAP", "Samba/SMB", "SSSD"],
  },
  {
    name: "Identity & Security",
    items: ["Okta (SCIM provisioning)", "Active Directory", "Group Policy / GPO", "FSMO roles", "OS hardening", "firewalld / ufw", "SSO administration"],
  },
  {
    name: "Cloud & Containers",
    items: ["AWS (EC2, S3, Lambda, RDS, SQS, API Gateway)", "Docker", "Kubernetes", "OpenShift"],
  },
  {
    name: "Automation & CI/CD",
    items: ["Ansible Automation Platform", "Jenkins", "GitLab", "Tray.io", "Apache Airflow", "Azkaban"],
  },
  {
    name: "Monitoring & Logging",
    items: ["Splunk", "Dynatrace"],
  },
  {
    name: "Databases",
    items: ["PostgreSQL", "MySQL", "Oracle SQL Developer", "Greenplum"],
  },
  {
    name: "Productivity & SaaS",
    items: ["Google Workspace administration", "Talkdesk", "Unifi"],
  },
];
---

<section id="skills">
  <div class="container">
    <span class="section-label">skills</span>
    <h2>What I work with</h2>
    <div class="skill-grid">
      {
        skillGroups.map((group) => (
          <div class="card skill-card">
            <h3>{group.name}</h3>
            <div class="tags">
              {group.items.map((item) => (
                <span class="tag">{item}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .skill-card h3 {
    margin-bottom: 0.85rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
